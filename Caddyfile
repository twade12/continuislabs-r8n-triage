r8n.continuislabs.cloud {
	encode gzip

	# Upstream is the r8n service on the Docker bridge network
	reverse_proxy r8n:8000

	# Long-lived static assets
	@static path /static/*
	header @static Cache-Control "public, max-age=86400, immutable"

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Logs go to stdout — visible via `docker compose logs caddy`
	log {
		output stdout
		format json
	}
}
