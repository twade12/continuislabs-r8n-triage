# r8n-triage environment variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.

# Admin UI credentials (HTTP Basic Auth)
# Protects /dash /sims /audit /codex /bulk /onboard /conductor /fleet /search
ADMIN_USER=admin
ADMIN_PASS=changeme   # CHANGE THIS before deploying

# SQLite database path (defaults to web/hgm-web.sqlite if not set)
# DB_PATH=/var/lib/r8n/r8n.sqlite

# Uvicorn port (used by start.sh)
PORT=8000
