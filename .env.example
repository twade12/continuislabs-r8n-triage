# r8n-triage environment variables
# cp .env.example .env  then edit before running docker compose up

# ---- Admin credentials (HTTP Basic Auth) ----
# Protects /dash /sims /audit /codex /bulk /onboard /conductor /fleet /search
ADMIN_USER=admin
ADMIN_PASS=changeme        # CHANGE THIS — pick a strong password

# ---- Database ----
# In Docker this path is inside the container; the named volume maps to it.
# Leave as-is unless you have a specific reason to change it.
DB_PATH=/data/r8n.sqlite

# ---- App port (internal, inside the container) ----
# Caddy talks to the container on this port. Don't expose it to the host.
PORT=8000
