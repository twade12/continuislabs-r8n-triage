# r8n-triage environment variables
# cp .env.example .env  then edit before running docker compose up

# ---- Admin credentials (HTTP Basic Auth) ----
# Protects /dash /sims /audit /codex /bulk /onboard /conductor /fleet /search
ADMIN_USER=admin
ADMIN_PASS=changeme        # CHANGE THIS — pick a strong password

# ---- Database ----
# In Docker this path is inside the container; the named volume maps to it.
# Leave as-is unless you have a specific reason to change it.
DB_PATH=/data/r8n.sqlite

# ---- App port (internal, inside the container) ----
# Caddy talks to the container on this port. Don't expose it to the host.
PORT=8000

# ---- Public URL ----
# Required in production so OAuth callbacks use the correct hostname.
# Must match the registered callback URL in your Google/GitHub OAuth apps.
APP_URL=https://r8n.continuislabs.cloud

# ---- Session secret ----
# Long random string — used to sign/encrypt the session cookie.
# Generate one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-random-hex

# ---- Google OAuth ----
# Create at: https://console.developers.google.com/
# Add Authorized redirect URI: https://r8n.continuislabs.cloud/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- GitHub OAuth ----
# Create at: https://github.com/settings/applications/new
# Homepage URL:      https://r8n.continuislabs.cloud
# Callback URL:      https://r8n.continuislabs.cloud/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- PostHog analytics ----
# Sign up free at https://posthog.com — get your project API key from Project Settings.
# Leave blank to disable all analytics (the app works fine without it).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
